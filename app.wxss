page {
  --bg-page: #F4F7FB;
  --bg-card: #FFFFFF;
  --bg-muted: #EEF3F8;
  --bg-input: #FFFFFF;
  --text-primary: #1F2937;
  --text-secondary: #5B6472;
  --text-muted: #8A94A6;
  --border-color: #D9E2EC;
  --border-strong: #B8C5D6;
  --blue-color: #1976D2;
  --blue-color-strong: #125DB1;
  --blue-color-deep: #0D47A1;
  --blue-color-soft: #E8F2FE;
  --red-color: #D32F2F;
  --red-color-strong: #B71C1C;
  --red-color-deep: #8E1717;
  --red-color-soft: #FDECEC;
  --green-color: #43A047;
  --green-color-strong: #2E7D32;
  --warning-color: #F59E0B;
  --warning-color-strong: #D97706;
  --chart-blue-out: #64B5F6;
  --chart-blue-in: #90CAF9;
  --chart-red-out: #EF5350;
  --chart-red-in: #FFCDD2;
  --text-on-primary: #FFFFFF;
  --blue-bg: #E8F2FE;
  --red-bg: #FDECEC;
  --success-bg: #EAF6EC;
  --warning-bg: #FFF4E5;
  --overlay-scrim: rgba(15, 23, 42, 0.48);
  --card-border-soft: rgba(217, 226, 236, 0.7);
  --control-shadow-primary: 0 12rpx 24rpx rgba(25, 118, 210, 0.2);
  --danger-shadow: rgba(211, 47, 47, 0.18);
  --shadow-card: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  --shadow-control: 0 2rpx 8rpx rgba(15, 23, 42, 0.05);
  background-color: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
}

.card {
  background-color: var(--bg-card);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid var(--card-border-soft);
}

.btn-primary {
  background: linear-gradient(135deg, var(--blue-color) 0%, var(--blue-color-strong) 100%);
  color: var(--text-on-primary);
  border-radius: 18rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: var(--control-shadow-primary);
}

.btn-primary:active {
  opacity: 0.92;
}

.btn-secondary {
  background-color: var(--bg-card);
  color: var(--blue-color);
  border: 2rpx solid var(--blue-color-soft);
  border-radius: 18rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: var(--shadow-control);
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  font-weight: 600;
}

.header-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.online-pill {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-control);
  color: var(--text-secondary);
}

.guest-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-height: 58rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background-color: var(--warning-bg);
  border: 1rpx solid var(--warning-color);
  box-shadow: var(--shadow-control);
}

.guest-label {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.guest-action {
  color: var(--warning-color-strong);
  font-size: 24rpx;
  font-weight: 700;
}

.online-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: var(--text-muted);
}

.online-pill.ready .online-dot {
  background-color: var(--green-color);
  box-shadow: 0 0 0 6rpx var(--success-bg);
}

.online-label,
.online-unit {
  font-size: 24rpx;
}

.online-count {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1;
}

.theme-toggle {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-card);
  border-radius: 999rpx;
  font-size: 30rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-control);
}

.app-icon {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  color: currentColor;
}

.app-icon::before,
.app-icon::after {
  content: "";
  position: absolute;
  box-sizing: border-box;
}

.icon-theme {
  color: var(--blue-color);
}

.icon-theme.is-sun::before {
  width: 22rpx;
  height: 22rpx;
  border-radius: 50%;
  background-color: currentColor;
  box-shadow: 0 -16rpx 0 -7rpx currentColor, 0 16rpx 0 -7rpx currentColor, 16rpx 0 0 -7rpx currentColor, -16rpx 0 0 -7rpx currentColor;
}

.icon-theme.is-moon::before {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background-color: currentColor;
}

.icon-theme.is-moon::after {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: var(--bg-card);
  transform: translate(8rpx, -5rpx);
}

.icon-calendar::before {
  width: 30rpx;
  height: 28rpx;
  border: 3rpx solid currentColor;
  border-radius: 7rpx;
}

.icon-calendar::after {
  width: 18rpx;
  height: 3rpx;
  background-color: currentColor;
  border-radius: 999rpx;
  transform: translateY(-5rpx);
}

.icon-search::before {
  width: 22rpx;
  height: 22rpx;
  border: 3rpx solid currentColor;
  border-radius: 50%;
  transform: translate(-3rpx, -3rpx);
}

.icon-search::after {
  width: 14rpx;
  height: 4rpx;
  background-color: currentColor;
  border-radius: 999rpx;
  transform: translate(10rpx, 10rpx) rotate(45deg);
}

.icon-export::before {
  width: 26rpx;
  height: 26rpx;
  border: 3rpx solid currentColor;
  border-radius: 6rpx;
  transform: translateY(3rpx);
}

.icon-export::after {
  width: 14rpx;
  height: 14rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: translateY(-7rpx) rotate(45deg);
}

.icon-backup::before {
  width: 30rpx;
  height: 18rpx;
  border: 3rpx solid currentColor;
  border-radius: 999rpx;
  transform: translateY(5rpx);
}

.icon-backup::after {
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid currentColor;
  border-top: 4rpx solid currentColor;
  transform: translateY(-7rpx) rotate(45deg);
}

.icon-route::before {
  width: 30rpx;
  height: 22rpx;
  border-left: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  border-radius: 0 0 0 12rpx;
  transform: translate(-2rpx, -2rpx);
}

.icon-route::after {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: currentColor;
  box-shadow: 20rpx 18rpx 0 currentColor;
}

.icon-empty::before {
  width: 42rpx;
  height: 30rpx;
  border: 3rpx solid currentColor;
  border-radius: 10rpx;
}

.icon-empty::after {
  width: 20rpx;
  height: 4rpx;
  background-color: currentColor;
  border-radius: 999rpx;
  transform: translateY(1rpx);
}

.date-display,
.picker-btn,
.route-picker-btn,
.filter-item,
.filter-value,
.date-picker {
  background-color: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 18rpx;
  box-shadow: var(--shadow-control);
}

.date-display,
.route-picker-btn {
  min-height: 80rpx;
  padding: 18rpx 22rpx;
}

.date-text,
.route-text,
.picker-btn,
.filter-value,
.date-picker {
  color: var(--text-primary);
}

.date-arrow,
.route-arrow,
.clear-btn {
  color: var(--text-muted);
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 999rpx;
  padding: 0 22rpx;
  min-height: 76rpx;
  box-shadow: var(--shadow-control);
}

.search-input {
  flex: 1;
  min-height: 76rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.quick-date-item,
.quick-btn,
.filter-btn,
.filter-reset,
.filter-apply,
.export-btn,
.backup-btn,
.modal-btn.confirm {
  border-radius: 16rpx;
  border: 1rpx solid transparent;
  box-shadow: var(--shadow-control);
}

.quick-date-item,
.quick-btn,
.filter-btn,
.filter-reset {
  background-color: var(--bg-card);
  color: var(--text-secondary);
  border-color: var(--border-color);
}

.quick-date-item.active,
.filter-apply,
.export-btn,
.modal-btn.confirm {
  background: linear-gradient(135deg, var(--blue-color) 0%, var(--blue-color-strong) 100%);
  color: var(--text-on-primary);
  border-color: var(--blue-color-strong);
}

.backup-btn,
.export-btn.highlight {
  background: linear-gradient(135deg, var(--green-color) 0%, var(--green-color-strong) 100%);
  color: var(--text-on-primary);
}

.dark-theme {
