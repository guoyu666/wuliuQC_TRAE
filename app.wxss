page {
  --bg-page: #F4F7FB;
  --bg-card: #FFFFFF;
  --bg-muted: #EEF3F8;
  --bg-input: #FFFFFF;
  --text-primary: #1F2937;
  --text-secondary: #5B6472;
  --text-muted: #8A94A6;
  --border-color: #D9E2EC;
  --border-strong: #B8C5D6;
  --blue-color: #1976D2;
  --red-color: #D32F2F;
  --blue-bg: #E8F2FE;
  --red-bg: #FDECEC;
  --success-bg: #EAF6EC;
  --warning-bg: #FFF4E5;
  --shadow-card: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
  --shadow-control: 0 2rpx 8rpx rgba(15, 23, 42, 0.05);
  background-color: var(--bg-page);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Segoe UI, Arial, Roboto, 'PingFang SC', 'miui', 'Hiragino Sans GB', 'Microsoft Yahei', sans-serif;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
}

.card {
  background-color: var(--bg-card);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  border: 1rpx solid rgba(217, 226, 236, 0.7);
}

.btn-primary {
  background: linear-gradient(135deg, #1976D2 0%, #125DB1 100%);
  color: #FFFFFF;
  border-radius: 18rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 12rpx 24rpx rgba(25, 118, 210, 0.2);
}

.btn-primary:active {
  opacity: 0.92;
}

.btn-secondary {
  background-color: var(--bg-card);
  color: var(--blue-color);
  border: 2rpx solid rgba(25, 118, 210, 0.16);
  border-radius: 18rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: var(--shadow-control);
}

.section-title {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  font-weight: 600;
}

.header-bar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 16rpx;
}

.theme-toggle {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-card);
  border-radius: 999rpx;
  font-size: 30rpx;
  border: 1rpx solid var(--border-color);
  box-shadow: var(--shadow-control);
}

.date-display,
.picker-btn,
.route-picker-btn,
.filter-item,
.filter-value,
.date-picker {
  background-color: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 18rpx;
  box-shadow: var(--shadow-control);
}

.date-display,
.route-picker-btn {
  min-height: 80rpx;
  padding: 18rpx 22rpx;
}

.date-text,
.route-text,
.picker-btn,
.filter-value,
.date-picker {
  color: var(--text-primary);
}

.date-arrow,
.route-arrow,
.clear-btn {
  color: var(--text-muted);
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 999rpx;
  padding: 0 22rpx;
  min-height: 76rpx;
  box-shadow: var(--shadow-control);
}

.search-input {
  flex: 1;
  min-height: 76rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.quick-date-item,
.quick-btn,
.filter-btn,
.filter-reset,
.filter-apply,
.export-btn,
.backup-btn,
.modal-btn.confirm {
  border-radius: 16rpx;
  border: 1rpx solid transparent;
  box-shadow: var(--shadow-control);
}

.quick-date-item,
.quick-btn,
.filter-btn,
.filter-reset {
  background-color: var(--bg-card);
  color: var(--text-secondary);
  border-color: var(--border-color);
}

.quick-date-item.active,
.filter-apply,
.export-btn,
.modal-btn.confirm {
  background: linear-gradient(135deg, #1976D2 0%, #125DB1 100%);
  color: #FFFFFF;
  border-color: rgba(18, 93, 177, 0.35);
}

.backup-btn,
.export-btn.highlight {
  background: linear-gradient(135deg, #43A047 0%, #2E7D32 100%);
  color: #FFFFFF;
}

.dark-theme {
  --bg-primary: #1a1a2e;
  --bg-secondary: #16213e;
  --bg-card: #1f2937;
  --bg-input: #374151;
  --text-primary: #F3F4F6;
  --text-secondary: #9CA3AF;
  --text-muted: #6B7280;
  --border-color: #374151;
  --blue-color: #60A5FA;
  --red-color: #F87171;
  --blue-bg: #1E3A5F;
  --red-bg: #5C2B2B;
  --blue-light: #DBEAFE;
  --red-light: #FEE2E2;
  --success-bg: #064E3B;
  --warning-bg: #78350F;
  --shadow-color: rgba(0, 0, 0, 0.3);
  --bg-page: #111827;
  --bg-card: #1F2937;
  --bg-muted: #273345;
  --bg-input: #334155;
  --text-primary: #F3F4F6;
  --text-secondary: #CBD5E1;
  --text-muted: #94A3B8;
  --border-color: #334155;
  --border-strong: #475569;
  --blue-color: #60A5FA;
  --red-color: #F87171;
  --blue-bg: #1E3A5F;
  --red-bg: #5C2B2B;
  --shadow-card: 0 12rpx 28rpx rgba(0, 0, 0, 0.3);
  --shadow-control: 0 4rpx 12rpx rgba(0, 0, 0, 0.18);
}

.dark-theme page {
  background-color: var(--bg-page);
}

.dark-theme .container {
  background-color: var(--bg-page);
}

.dark-theme .card {
  background-color: var(--bg-card);
  box-shadow: var(--shadow-card);
  border-color: rgba(51, 65, 85, 0.9);
}

.dark-theme .date-display,
.dark-theme .picker-btn,
.dark-theme .route-picker-btn,
.dark-theme .search-input,
.dark-theme .remark-input,
.dark-theme .edit-picker-btn,
.dark-theme .edit-inline-input,
.dark-theme .filter-value,
.dark-theme .filter-item,
.dark-theme .stepper-input,
.dark-theme .remark-edit-input {
  background-color: var(--bg-input);
  color: var(--text-primary);
}

.dark-theme .date-text,
.dark-theme .quick-date-item,
.dark-theme .section-title,
.dark-theme .date-label,
.dark-theme .input-label,
.dark-theme .input-name,
.dark-theme .cell-label,
.dark-theme .summary-label,
.dark-theme .summary-value,
.dark-theme .chart-title,
.dark-theme .bar-label,
.dark-theme .bar-value,
.dark-theme .trend-date,
.dark-theme .trend-num,
.dark-theme .record-route,
.dark-theme .record-plate,
.dark-theme .record-time,
.dark-theme .record-detail,
.dark-theme .group-route,
.dark-theme .group-plate,
.dark-theme .group-cell,
.dark-theme .empty-text,
.dark-theme .loading-text,
.dark-theme .no-more-text,
.dark-theme .modal-header,
.dark-theme .input-section-title,
.dark-theme .collapse-title,
.dark-theme .input-name,
.dark-theme .cell-label,
.dark-theme .export-preview .preview-title,
.dark-theme .stat-item {
  color: var(--text-primary);
}

.dark-theme .text-secondary,
.dark-theme .empty-hint,
.dark-theme .filter-label,
.dark-theme .filter-gap,
.dark-theme .input-label {
  color: var(--text-secondary);
}

.dark-theme .record-remark {
  color: var(--text-muted);
}

.dark-theme .search-input::placeholder,
.dark-theme .remark-input::placeholder,
.dark-theme .remark-edit-input::placeholder,
.dark-theme .inline-input::placeholder,
.dark-theme .edit-inline-input::placeholder {
  color: var(--text-muted);
}

.dark-theme .date-arrow,
.dark-theme .route-arrow,
.dark-theme .collapse-arrow,
.dark-theme .group-arrow,
.dark-theme .clear-btn {
  color: var(--text-muted);
}

.dark-theme .export-btn,
.dark-theme .filter-btn,
.dark-theme .quick-btn,
.dark-theme .btn-primary,
.dark-theme .btn-secondary,
.dark-theme .modal-btn.confirm,
.dark-theme .filter-apply,
.dark-theme .export-btn.highlight {
  background-color: var(--bg-secondary);
  color: var(--text-primary);
}

.dark-theme .edit-btn,
.dark-theme .remark-btn {
  color: var(--blue-color);
  background-color: var(--blue-bg);
}

.dark-theme .delete-btn {
  color: var(--red-color);
  background-color: var(--red-bg);
}

.dark-theme .btn-primary {
  background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
}

.dark-theme .filter-reset {
  background-color: var(--bg-secondary);
  color: var(--text-primary);
}

.dark-theme .summary-card,
.dark-theme .header-card,
.dark-theme .chart-card,
.dark-theme .input-card,
.dark-theme .group-list-card {
  background-color: var(--bg-card);
}

.dark-theme .record-item,
.dark-theme .group-header,
.dark-theme .group-detail,
.dark-theme .group-detail .group-row,
.dark-theme .filter-panel,
.dark-theme .collapse-content {
  background-color: var(--bg-secondary);
}

.dark-theme .group-item {
  background-color: var(--bg-secondary);
}

.dark-theme .collapse-header {
  background-color: var(--bg-card);
}

.dark-theme .modal-content {
  background-color: var(--bg-card);
}

.dark-theme .modal-mask {
