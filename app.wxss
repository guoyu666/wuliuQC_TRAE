  --bg-primary: #111827;
  --bg-secondary: #16213E;
  --bg-card: #1F2937;
  --bg-muted: #273345;
  --bg-input: #334155;
  --text-primary: #F3F4F6;
  --text-secondary: #CBD5E1;
  --text-muted: #94A3B8;
  --border-color: #334155;
  --border-strong: #475569;
  --blue-color: #60A5FA;
  --blue-color-strong: #3B82F6;
  --blue-color-deep: #2563EB;
  --blue-color-soft: #1E3A5F;
  --red-color: #F87171;
  --red-color-strong: #EF4444;
  --red-color-deep: #DC2626;
  --red-color-soft: #5C2B2B;
  --green-color: #4ADE80;
  --green-color-strong: #22C55E;
  --warning-color: #FBBF24;
  --warning-color-strong: #F59E0B;
  --chart-blue-out: #3B82F6;
  --chart-blue-in: #93C5FD;
  --chart-red-out: #EF4444;
  --chart-red-in: #FCA5A5;
  --text-on-primary: #FFFFFF;
  --blue-bg: #1E3A5F;
  --red-bg: #5C2B2B;
  --success-bg: #064E3B;
  --warning-bg: #78350F;
  --overlay-scrim: rgba(0, 0, 0, 0.7);
  --card-border-soft: rgba(51, 65, 85, 0.9);
  --control-shadow-primary: 0 12rpx 24rpx rgba(96, 165, 250, 0.18);
  --danger-shadow: rgba(248, 113, 113, 0.18);
  --shadow-card: 0 12rpx 28rpx rgba(0, 0, 0, 0.3);
