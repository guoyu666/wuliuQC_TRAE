<view class="container">
  <view class="bg-decoration">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
    <view class="bg-circle bg-circle-3"></view>
  </view>

  <view class="content">
    <view class="logo-section">
      <view class="logo-wrapper">
        <view class="logo">📦</view>
      </view>
      <view class="app-name">烟框收发记录</view>
      <view class="app-desc">库房管理更轻松</view>
    </view>

    <view class="features">
      <view class="feature-item">
        <view class="feature-icon">📝</view>
        <view class="feature-text">快速记录收发</view>
      </view>
      <view class="feature-item">
        <view class="feature-icon">📊</view>
        <view class="feature-text">数据可视化</view>
      </view>
      <view class="feature-item">
        <view class="feature-icon">📋</view>
        <view class="feature-text">历史记录查询</view>
      </view>
      <view class="feature-item">
        <view class="feature-icon">📈</view>
        <view class="feature-text">统计报表分析</view>
      </view>
    </view>

    <view class="login-card">
      <view class="login-title">{{isAuthorized ? (isCheckingAuth ? '正在确认微信账号' : '已登录微信账号') : '先体验，后登录'}}</view>
      <view class="login-desc">
        {{isAuthorized ? (isCheckingAuth ? '已识别当前微信账号，正在确认云同步状态' : (isCloudUnavailable ? '已识别当前微信账号，云同步暂不可用，可手动重试' : '数据将按当前微信账号同步')) : '无需登录即可浏览、记录、查询和统计；体验后可自愿登录开启云同步'}}
      </view>
      <view class="user-row" wx:if="{{isAuthorized && userInfo}}">
        <image class="avatar" wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <view class="avatar placeholder" wx:else>微</view>
        <view class="nickname">{{userInfo.nickName || '微信用户'}}</view>
      </view>
    </view>

    <button class="start-btn" bindtap="goToIndex">
      <text>{{isAuthorized ? '返回使用' : '先体验功能'}}</text>
    </button>

    <button class="login-sync-btn" loading="{{isLoading}}" disabled="{{isLoading}}" bindtap="loginWithWechat" wx:if="{{!isAuthorized || isCheckingAuth || isCloudUnavailable}}">
      <text>{{isCheckingAuth ? '继续确认同步' : (isCloudUnavailable ? '重试云同步' : '登录并开启云同步')}}</text>
    </button>

    <view class="experience-tip" wx:if="{{!isAuthorized}}">登录完全自愿，不获取手机号、头像和昵称</view>

    <view class="privacy-tip" bindtap="showPrivacyInfo">
      查看登录与数据说明
    </view>
  </view>
</view>
