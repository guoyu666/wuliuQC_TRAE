<view class="container">
  <view class="bg-decoration">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
    <view class="bg-circle bg-circle-3"></view>
  </view>

  <view class="content">
    <view class="logo-section">
      <view class="logo-wrapper">
        <view class="logo">📦</view>
      </view>
      <view class="app-name">烟框收发记录</view>
      <view class="app-desc">库房管理更轻松</view>
    </view>

    <view class="features">
      <view class="feature-item">
        <view class="feature-icon">📝</view>
        <view class="feature-text">快速记录收发</view>
      </view>
      <view class="feature-item">
        <view class="feature-icon">📊</view>
        <view class="feature-text">数据可视化</view>
      </view>
      <view class="feature-item">
        <view class="feature-icon">📋</view>
        <view class="feature-text">历史记录查询</view>
      </view>
      <view class="feature-item">
        <view class="feature-icon">📈</view>
        <view class="feature-text">统计报表分析</view>
      </view>
    </view>

    <view class="login-card">
      <view class="login-title">{{isAuthorized ? '已授权微信账号' : '微信账号授权同步'}}</view>
      <view class="login-desc">
        {{isAuthorized ? (isCloudUnavailable ? '已识别当前微信账号，云同步暂不可用，可重试登录同步' : '将根据当前微信账号同步您的个人记录') : '授权后可在不同设备间同步自己的线路、车牌和历史记录'}}
      </view>
      <view class="user-row" wx:if="{{isAuthorized && userInfo}}">
        <image class="avatar" wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
        <view class="avatar placeholder" wx:else>微</view>
        <view class="nickname">{{userInfo.nickName || '微信用户'}}</view>
      </view>
    </view>

    <button class="start-btn" loading="{{isLoading}}" disabled="{{isLoading}}" bindtap="loginWithWechat">
      <text>{{isAuthorized ? (isCloudUnavailable ? '重试云同步' : '进入应用') : '微信授权并同步'}}</text>
    </button>

    <view class="privacy-tip" bindtap="showPrivacyInfo">
      查看授权与数据说明
    </view>
  </view>
</view>
