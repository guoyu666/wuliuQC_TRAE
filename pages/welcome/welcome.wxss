.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #1E88E5 0%, #1565C0 50%, #0D47A1 100%);
  position: relative;
  overflow: hidden;
}

.bg-decoration {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  overflow: hidden;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.bg-circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -100rpx;
  right: -100rpx;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  bottom: 80rpx;
  left: -80rpx;
}

.bg-circle-3 {
  width: 200rpx;
  height: 200rpx;
  top: 50%;
  right: -50rpx;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 60rpx 48rpx;
  position: relative;
  z-index: 1;
}

.logo-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-wrapper {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 32rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.logo {
  font-size: 72rpx;
}

.app-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
}

.features {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 36rpx;
  padding: 0 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  backdrop-filter: blur(10px);
}

.feature-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #FFFFFF;
}

.login-card {
  margin: 0 10rpx 32rpx;
  padding: 30rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  box-shadow: 0 16rpx 40rpx rgba(0, 0, 0, 0.14);
  backdrop-filter: blur(12px);
  text-align: center;
}

.login-title {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.login-desc {
  color: rgba(255, 255, 255, 0.78);
  font-size: 24rpx;
  line-height: 1.6;
}

.user-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  color: #1976D2;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nickname {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  max-width: 420rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.start-btn {
  background: rgba(255, 255, 255, 0.95);
  color: #1976D2;
  border-radius: 50rpx;
  padding: 28rpx 0;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
  line-height: 1.4;
}

.start-btn::after {
  border: 0;
}

.start-btn[disabled] {
  opacity: 0.78;
  color: #1976D2;
  background: rgba(255, 255, 255, 0.82);
}

.start-btn:active {
  transform: scale(0.98);
}

.login-sync-btn {
  margin-top: 20rpx;
  padding: 24rpx 0;
  color: #FFFFFF;
  background: rgba(13, 71, 161, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.login-sync-btn::after {
  border: 0;
}

.login-sync-btn[disabled] {
  opacity: 0.7;
  color: #FFFFFF;
}

.experience-tip {
  margin-top: 18rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 22rpx;
  line-height: 1.5;
  text-align: center;
}

.privacy-tip {
  margin-top: 22rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 22rpx;
  text-align: center;
}
