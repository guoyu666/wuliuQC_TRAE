.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #1E88E5 0%, #1565C0 50%, #0D47A1 100%);
  position: relative;
  overflow: hidden;
}

.bg-decoration {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  overflow: hidden;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.bg-circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -100rpx;
  right: -100rpx;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  bottom: 80rpx;
  left: -80rpx;
}

.bg-circle-3 {
  width: 200rpx;
  height: 200rpx;
  top: 50%;
  right: -50rpx;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 60rpx 48rpx;
  position: relative;
  z-index: 1;
}

.logo-section {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-wrapper {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 32rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.logo {
  font-size: 72rpx;
}

.app-name {
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.app-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
}

.features {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 60rpx;
  padding: 0 20rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  backdrop-filter: blur(10px);
}

.feature-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #FFFFFF;
}

.start-btn {
  background: rgba(255, 255, 255, 0.95);
  color: #1976D2;
  border-radius: 50rpx;
  padding: 28rpx 0;
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
}

.start-btn:active {
  transform: scale(0.98);
}
