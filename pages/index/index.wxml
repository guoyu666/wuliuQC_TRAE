<view class="container">
  <view class="date-selector">
    <view class="date-picker-wrap">
      <picker mode="date" value="{{selectedDate}}" start="2020-01-01" end="2099-12-31" bindchange="onDateChange">
        <view class="date-display">
          <text class="date-icon">📅</text>
          <text class="date-text">{{selectedDate}}</text>
          <text class="date-arrow">▼</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="quick-date">
    <view class="quick-date-item {{quickType === 'today' ? 'active' : ''}}" bindtap="goToToday">今天</view>
    <view class="quick-date-item {{quickType === 'yesterday' ? 'active' : ''}}" bindtap="goToYesterday">昨天</view>
    <view class="quick-date-item {{quickType === 'lastWeek' ? 'active' : ''}}" bindtap="goToLastWeek">上周</view>
    <view class="quick-date-item {{quickType === 'monthStart' ? 'active' : ''}}" bindtap="goToMonthStart">月初</view>
  </view>

  <view class="center-send-card card">
    <view class="section-title">物流中心发出框子数量</view>
    <view class="send-input-row">
      <view class="send-input-item">
        <view class="send-label blue">蓝色框子</view>
        <view class="send-stepper">
          <view class="stepper-btn" bindtap="adjustSendValue" data-field="sendBlueOut" data-delta="-1">-</view>
          <input class="stepper-input" type="number" value="{{sendBlueOut}}" bindinput="onSendBlueOutChange" />
          <view class="stepper-btn" bindtap="adjustSendValue" data-field="sendBlueOut" data-delta="1">+</view>
        </view>
      </view>
      <view class="send-input-item">
        <view class="send-label red">红色框子</view>
        <view class="send-stepper">
          <view class="stepper-btn" bindtap="adjustSendValue" data-field="sendRedOut" data-delta="-1">-</view>
          <input class="stepper-input" type="number" value="{{sendRedOut}}" bindinput="onSendRedOutChange" />
          <view class="stepper-btn" bindtap="adjustSendValue" data-field="sendRedOut" data-delta="1">+</view>
        </view>
      </view>
    </view>
  </view>

  <view class="header-card card" animation="{{animationData}}">
    <view class="date-label">当日收发汇总</view>
    <view class="summary-row">
      <view class="summary-item blue">
        <view class="summary-label">蓝色发出</view>
        <view class="summary-value">{{todayBlueOut}}</view>
      </view>
      <view class="summary-item blue">
        <view class="summary-label">蓝色收回</view>
        <view class="summary-value">{{todayBlueIn}}</view>
      </view>
    </view>
    <view class="summary-row">
      <view class="summary-item red">
        <view class="summary-label">红色发出</view>
        <view class="summary-value">{{todayRedOut}}</view>
      </view>
      <view class="summary-item red">
        <view class="summary-label">红色收回</view>
        <view class="summary-value">{{todayRedIn}}</view>
      </view>
    </view>
    <view class="record-count">共 {{todayRecordCount}} 条记录</view>
  </view>

  <view class="chart-card card">
    <view class="chart-title">数据可视化</view>
    <view class="chart-container" animation="{{animationData}}">
      <view class="chart-row">
        <view class="chart-item">
          <view class="bar-wrapper">
            <view class="bar-value-top">{{todayBlueOut}}</view>
            <view class="bar blue-out" style="height: {{barBlueOut}}rpx;"></view>
            <view class="bar blue-in" style="height: {{barBlueIn}}rpx;"></view>
            <view class="bar-value-bottom">{{todayBlueIn}}</view>
          </view>
          <view class="bar-label">蓝色框子</view>
        </view>
        <view class="chart-item">
          <view class="bar-wrapper">
            <view class="bar-value-top">{{todayRedOut}}</view>
            <view class="bar red-out" style="height: {{barRedOut}}rpx;"></view>
            <view class="bar red-in" style="height: {{barRedIn}}rpx;"></view>
            <view class="bar-value-bottom">{{todayRedIn}}</view>
          </view>
          <view class="bar-label">红色框子</view>
        </view>
      </view>
    </view>
    <view class="chart-legend">
      <view class="legend-item">
        <view class="legend-color legend-blue-out"></view>
        <text>蓝色发出</text>
      </view>
      <view class="legend-item">
        <view class="legend-color legend-blue-in"></view>
        <text>蓝色收回</text>
      </view>
      <view class="legend-item">
        <view class="legend-color legend-red-out"></view>
        <text>红色发出</text>
      </view>
      <view class="legend-item">
        <view class="legend-color legend-red-in"></view>
        <text>红色收回</text>
      </view>
    </view>
  </view>

  <view class="input-card card">
    <view class="section-title">新增记录</view>

    <view class="input-row-2">
      <view class="input-group flex-1">
        <view class="input-label">线路名称</view>
        <input class="text-input" placeholder="如：京沪线" value="{{routeName}}" bindinput="onRouteNameChange" />
      </view>
      <view class="input-group flex-1">
        <view class="input-label">车牌号</view>
        <input class="text-input" placeholder="如：京A12345" value="{{plateNumber}}" bindinput="onPlateNumberChange" />
      </view>
    </view>

    <view class="input-section">
      <view class="input-section-title blue-title">蓝色框子</view>
      <view class="input-row">
        <view class="input-item">
          <view class="input-name">物流发出</view>
          <view class="stepper">
            <view class="stepper-btn" bindtap="adjustSendValue" data-field="sendBlueOut" data-delta="-1">-</view>
            <input class="stepper-input" type="number" value="{{sendBlueOut}}" bindinput="onSendBlueOutChange" />
            <view class="stepper-btn" bindtap="adjustSendValue" data-field="sendBlueOut" data-delta="1">+</view>
          </view>
        </view>
        <view class="input-item">
          <view class="input-name">车辆发出</view>
          <view class="stepper">
            <view class="stepper-btn" bindtap="adjustValue" data-field="blueOut" data-delta="-1">-</view>
            <input class="stepper-input" type="number" value="{{blueOut}}" bindinput="onBlueOutChange" />
            <view class="stepper-btn" bindtap="adjustValue" data-field="blueOut" data-delta="1">+</view>
          </view>
        </view>
        <view class="input-item">
          <view class="input-name">车辆收回</view>
          <view class="stepper">
            <view class="stepper-btn" bindtap="adjustValue" data-field="blueIn" data-delta="-1">-</view>
            <input class="stepper-input" type="number" value="{{blueIn}}" bindinput="onBlueInChange" />
            <view class="stepper-btn" bindtap="adjustValue" data-field="blueIn" data-delta="1">+</view>
          </view>
        </view>
      </view>
    </view>

    <view class="input-section">
      <view class="input-section-title red-title">红色框子</view>
      <view class="input-row">
        <view class="input-item">
          <view class="input-name">物流发出</view>
          <view class="stepper">
            <view class="stepper-btn" bindtap="adjustSendValue" data-field="sendRedOut" data-delta="-1">-</view>
            <input class="stepper-input" type="number" value="{{sendRedOut}}" bindinput="onSendRedOutChange" />
            <view class="stepper-btn" bindtap="adjustSendValue" data-field="sendRedOut" data-delta="1">+</view>
          </view>
        </view>
        <view class="input-item">
          <view class="input-name">车辆发出</view>
          <view class="stepper">
            <view class="stepper-btn" bindtap="adjustValue" data-field="redOut" data-delta="-1">-</view>
            <input class="stepper-input" type="number" value="{{redOut}}" bindinput="onRedOutChange" />
            <view class="stepper-btn" bindtap="adjustValue" data-field="redOut" data-delta="1">+</view>
          </view>
        </view>
        <view class="input-item">
          <view class="input-name">车辆收回</view>
          <view class="stepper">
            <view class="stepper-btn" bindtap="adjustValue" data-field="redIn" data-delta="-1">-</view>
            <input class="stepper-input" type="number" value="{{redIn}}" bindinput="onRedInChange" />
            <view class="stepper-btn" bindtap="adjustValue" data-field="redIn" data-delta="1">+</view>
          </view>
        </view>
      </view>
    </view>

    <view class="input-group">
      <view class="input-label">备注（选填）</view>
      <textarea class="remark-input" placeholder="请输入备注信息..." value="{{remark}}" bindinput="onRemarkChange" maxlength="200"></textarea>
    </view>
  </view>

  <view class="btn-primary submit-btn" bindtap="submitRecord">提交记录</view>

  <view class="btn-row">
    <view class="btn-secondary" bindtap="goToStatistics">统计报表</view>
    <view class="btn-secondary" bindtap="goToHistory">历史记录</view>
  </view>
</view>