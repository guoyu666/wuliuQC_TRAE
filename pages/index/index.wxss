.date-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.date-picker-wrap {
  flex: 1;
}

.date-display {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.date-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 600;
}

.date-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-left: 12rpx;
}

.today-btn {
  background-color: var(--blue-color);
  color: var(--text-on-primary);
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-left: 20rpx;
}

.quick-date {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 14rpx;
}

.quick-date-item {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  font-weight: 500;
}

.quick-date-item.active {
  font-weight: 600;
}

.center-send-card {
  text-align: center;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.center-send-card .section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.send-input-row {
  display: flex;
  justify-content: space-around;
}

.send-input-item {
  flex: 1;
  text-align: center;
}

.send-label {
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.send-label.blue {
  color: var(--blue-color);
}

.send-label.red {
  color: var(--red-color);
}

.send-stepper {
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-card {
  text-align: center;
  padding: 24rpx;
}

.date-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 16rpx;
}

.summary-row {
  display: flex;
  justify-content: space-around;
  padding: 12rpx 0;
}

.summary-row:first-child {
  border-bottom: 1rpx solid var(--border-color);
}

.summary-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
}

.summary-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 40rpx;
  font-weight: bold;
}

.summary-item.blue .summary-value {
  color: var(--blue-color);
}

.summary-item.red .summary-value {
  color: var(--red-color);
}

.record-count {
  font-size: 24rpx;
  color: var(--text-muted);
  text-align: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.chart-card {
  padding: 24rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.chart-container {
  padding: 0 20rpx;
}

.chart-row {
  display: flex;
  justify-content: space-around;
}

.chart-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 180rpx;
}

.bar-value-top {
  font-size: 22rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.bar-value-bottom {
  font-size: 22rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-top: 8rpx;
}

.bar {
  width: 40rpx;
  border-radius: 4rpx 4rpx 0 0;
}

.bar.blue-out {
  background: linear-gradient(180deg, var(--blue-color) 0%, var(--chart-blue-out) 100%);
}

.bar.blue-in {
  background: linear-gradient(180deg, var(--chart-blue-in) 0%, var(--blue-color) 100%);
}

.bar.red-out {
  background: linear-gradient(180deg, var(--red-color) 0%, var(--chart-red-out) 100%);
}

.bar.red-in {
  background: linear-gradient(180deg, var(--chart-red-in) 0%, var(--red-color) 100%);
}

.bar-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
}

.chart-legend {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  margin-right: 6rpx;
}

.legend-blue-out {
  background-color: var(--chart-blue-out);
}

.legend-blue-in {
  background-color: var(--chart-blue-in);
}

.legend-red-out {
  background-color: var(--chart-red-out);
}

.legend-red-in {
  background-color: var(--chart-red-in);
}

.group-list-card {
  padding: 24rpx;
  margin-top: 20rpx;
}

.group-list-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.group-item {
  background-color: var(--bg-muted);
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.group-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: var(--bg-card);
}

.group-info {
  flex: 1;
}

.group-route {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.group-plate {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.group-summary {
  display: flex;
  gap: 16rpx;
  font-size: 26rpx;
  margin-right: 16rpx;
}

.group-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
  transition: transform 0.3s;
}

.group-arrow.expanded {
  transform: rotate(180deg);
}

.group-detail {
  padding: 0 20rpx 20rpx;
  background-color: var(--bg-muted);
}

.group-detail.hidden {
  display: none;
}

.group-row {
  display: flex;
  justify-content: space-between;
  background-color: var(--bg-card);
  border-radius: 8rpx;
  padding: 16rpx;
}

.group-cell {
  flex: 1;
  text-align: center;
}

.cell-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.cell-values {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  font-size: 24rpx;
}

.blue-text {
  color: var(--blue-color);
}

.red-text {
  color: var(--red-color);
}

.route-summary-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.route-summary-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.route-summary-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.route-summary-item {
  background-color: var(--bg-muted);
  border-radius: 12rpx;
  padding: 16rpx;
}

.route-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.route-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.route-record-count {
  font-size: 22rpx;
  color: var(--text-muted);
}

.route-stats-row {
  display: flex;
  gap: 16rpx;
}

.route-stat {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.stat-values {
  display: flex;
  gap: 8rpx;
  font-size: 24rpx;
}

.blue-stat .stat-label {
  color: var(--blue-color);
}

.red-stat .stat-label {
  color: var(--red-color);
}

.stat-out {
  color: var(--text-primary);
}

.stat-in {
  color: var(--text-secondary);
}

.input-card {
  padding: 24rpx;
}

.input-section {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background-color: var(--bg-muted);
  border-radius: 12rpx;
}

.input-section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.collapse-section {
  margin-bottom: 16rpx;
  background-color: var(--bg-muted);
  border-radius: 12rpx;
  overflow: hidden;
}

.collapse-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
}

.collapse-title {
  font-size: 28rpx;
  font-weight: 600;
}

.collapse-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
  transition: transform 0.3s;
}

.collapse-arrow.expanded {
  transform: rotate(180deg);
}

.collapse-content {
  display: none;
  padding: 0 24rpx 20rpx;
}

.collapse-content.expanded {
  display: block;
}

.blue-title {
  color: var(--blue-color);
}

.red-title {
  color: var(--red-color);
}

.input-group {
  margin-bottom: 24rpx;
}

.input-row-2 {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.flex-1 {
  flex: 1;
}

.input-group:last-child {
  margin-bottom: 0;
}

.input-label {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.blue-label {
  color: var(--blue-color);
}

.red-label {
  color: var(--red-color);
}

.input-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.input-item {
  flex: 1;
  padding: 12rpx 8rpx;
  background-color: var(--bg-card);
  border-radius: 8rpx;
}

.input-name {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
  text-align: center;
}

.stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-muted);
  border-radius: 8rpx;
  padding: 6rpx;
}

.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  background-color: var(--bg-card);
  border-radius: 8rpx;
}

.stepper-input {
  width: 60rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 0 4rpx;
  background-color: var(--bg-card);
  border-radius: 6rpx;
}

.btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-row .btn-secondary {
  flex: 1;
  margin-top: 0;
}

.text-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: var(--bg-muted);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.picker-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
  min-width: 0;
}

.picker-main {
  flex: 1;
  min-width: 0;
}

.picker-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: var(--text-muted);
  background-color: var(--bg-muted);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.picker-btn.has-value {
  color: var(--text-primary);
}

.plate-picker-row {
  overflow-x: auto;
  overflow-y: hidden;
  -webkit-overflow-scrolling: touch;
}

.plate-picker-main {
  flex: 1 0 auto;
  min-width: 0;
}

.plate-picker-btn {
  display: inline-block;
  min-width: 100%;
  white-space: nowrap;
}

.inline-input {
  flex-shrink: 0;
  width: 100rpx;
  height: 72rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
  background-color: var(--blue-bg);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.delete-btn {
  flex-shrink: 0;
  width: 48rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 32rpx;
  color: var(--text-on-primary);
  background-color: var(--border-strong);
  border-radius: 8rpx;
  opacity: 0;
  pointer-events: none;
}

.delete-btn.show {
  background-color: var(--red-color);
  opacity: 1;
  pointer-events: auto;
}

.remark-input {
  width: 100%;
  min-height: 40rpx;
  padding: 12rpx;
  font-size: 28rpx;
  background-color: var(--bg-muted);
  border-radius: 12rpx;
  box-sizing: border-box;
}

.submit-btn {
  margin-top: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  background: linear-gradient(135deg, var(--blue-color) 0%, var(--blue-color) 100%);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx var(--control-shadow-primary);
}
