.date-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.date-picker-wrap {
  flex: 1;
}

.date-display {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.date-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.date-arrow {
  font-size: 20rpx;
  color: #999999;
  margin-left: 12rpx;
}

.today-btn {
  background-color: #1976D2;
  color: #FFFFFF;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-left: 20rpx;
}

.quick-date {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.quick-date-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666666;
  background-color: #FFFFFF;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.quick-date-item.active {
  background-color: #1976D2;
  color: #FFFFFF;
  font-weight: 500;
}

.center-send-card {
  text-align: center;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.center-send-card .section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
}

.send-input-row {
  display: flex;
  justify-content: space-around;
}

.send-input-item {
  flex: 1;
  text-align: center;
}

.send-label {
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.send-label.blue {
  color: #1976D2;
}

.send-label.red {
  color: #D32F2F;
}

.send-stepper {
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-card {
  text-align: center;
  padding: 24rpx;
}

.date-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.summary-row {
  display: flex;
  justify-content: space-around;
  padding: 12rpx 0;
}

.summary-row:first-child {
  border-bottom: 1rpx solid #EEEEEE;
}

.summary-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
}

.summary-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 40rpx;
  font-weight: bold;
}

.summary-item.blue .summary-value {
  color: #1976D2;
}

.summary-item.red .summary-value {
  color: #D32F2F;
}

.record-count {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEEEEE;
}

.chart-card {
  padding: 24rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 24rpx;
}

.chart-container {
  padding: 0 20rpx;
}

.chart-row {
  display: flex;
  justify-content: space-around;
}

.chart-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 180rpx;
}

.bar-value-top {
  font-size: 22rpx;
  color: #333333;
  font-weight: 500;
}

.bar-value-bottom {
  font-size: 22rpx;
  color: #333333;
  font-weight: 500;
  margin-top: 8rpx;
}

.bar {
  width: 40rpx;
  border-radius: 4rpx 4rpx 0 0;
}

.bar.blue-out {
  background: linear-gradient(180deg, #1565C0 0%, #0D47A1 100%);
}

.bar.blue-in {
  background: linear-gradient(180deg, #42A5F5 0%, #1E88E5 100%);
}

.bar.red-out {
  background: linear-gradient(180deg, #C62828 0%, #B71C1C 100%);
}

.bar.red-in {
  background: linear-gradient(180deg, #EF5350 0%, #E53935 100%);
}

.bar-label {
  font-size: 24rpx;
  color: #666666;
  margin-top: 12rpx;
}

.chart-legend {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEEEEE;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #666666;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  margin-right: 6rpx;
}

.legend-blue-out {
  background-color: #0D47A1;
}

.legend-blue-in {
  background-color: #42A5F5;
}

.legend-red-out {
  background-color: #B71C1C;
}

.legend-red-in {
  background-color: #EF5350;
}

.input-card {
  padding: 24rpx;
}

.input-section {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background-color: #FAFAFA;
  border-radius: 12rpx;
}

.input-section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.blue-title {
  color: #1976D2;
}

.red-title {
  color: #D32F2F;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-row-2 {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.flex-1 {
  flex: 1;
}

.input-group:last-child {
  margin-bottom: 0;
}

.input-label {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.blue-label {
  color: #1976D2;
}

.red-label {
  color: #D32F2F;
}

.input-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.input-item {
  flex: 1;
  padding: 12rpx 8rpx;
  background-color: #FFFFFF;
  border-radius: 8rpx;
}

.input-name {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 10rpx;
  text-align: center;
}

.stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  padding: 6rpx;
}

.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  background-color: #FFFFFF;
  border-radius: 8rpx;
}

.stepper-input {
  width: 60rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 0 4rpx;
  background-color: #FFFFFF;
  border-radius: 6rpx;
}

.btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-row .btn-secondary {
  flex: 1;
  margin-top: 0;
}

.text-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.remark-input {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  font-size: 28rpx;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.submit-btn {
  margin-top: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(25, 118, 210, 0.3);
}

.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.picker-input .placeholder {
  color: #999999;
}

.picker-arrow {
  font-size: 20rpx;
  color: #999999;
}

.preset-hint {
  font-size: 22rpx;
  color: #999999;
  margin-top: 12rpx;
}

.preset-bar {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
  padding: 0 4rpx;
}

.preset-btn {
  font-size: 24rpx;
  color: #1976D2;
  padding: 8rpx 16rpx;
}

.preset-modal .modal-body {
  max-height: 70vh;
  overflow-y: auto;
}

.preset-section {
  margin-bottom: 32rpx;
}

.preset-section:last-child {
  margin-bottom: 0;
}

.preset-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid #1976D2;
}

.preset-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.preset-item {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
  background-color: #E3F2FD;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333333;
}

.preset-item text {
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.preset-delete {
  margin-left: 12rpx;
  width: 36rpx;
  height: 36rpx;
  line-height: 32rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #D32F2F;
  background-color: #FFEBEE;
  border-radius: 50%;
}

.preset-add {
  display: flex;
  gap: 12rpx;
}

.preset-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.preset-add-btn {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  color: #FFFFFF;
  background-color: #1976D2;
  border-radius: 8rpx;
}
