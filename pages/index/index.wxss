.header-bar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 16rpx;
}

.theme-toggle {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  border-radius: 50%;
  font-size: 32rpx;
}

.date-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.date-picker-wrap {
  flex: 1;
}

.date-display {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.date-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.date-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #333333;
}

.date-arrow {
  font-size: 20rpx;
  color: #999999;
  margin-left: 12rpx;
}

.today-btn {
  background-color: #1976D2;
  color: #FFFFFF;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  margin-left: 20rpx;
}

.quick-date {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.quick-date-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #666666;
  background-color: #FFFFFF;
  border-radius: 8rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.quick-date-item.active {
  background-color: #1976D2;
  color: #FFFFFF;
  font-weight: 500;
}

.center-send-card {
  text-align: center;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.center-send-card .section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 20rpx;
}

.send-input-row {
  display: flex;
  justify-content: space-around;
}

.send-input-item {
  flex: 1;
  text-align: center;
}

.send-label {
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.send-label.blue {
  color: #1976D2;
}

.send-label.red {
  color: #D32F2F;
}

.send-stepper {
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-card {
  text-align: center;
  padding: 24rpx;
}

.date-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 16rpx;
}

.summary-row {
  display: flex;
  justify-content: space-around;
  padding: 12rpx 0;
}

.summary-row:first-child {
  border-bottom: 1rpx solid #EEEEEE;
}

.summary-item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
}

.summary-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 40rpx;
  font-weight: bold;
}

.summary-item.blue .summary-value {
  color: #1976D2;
}

.summary-item.red .summary-value {
  color: #D32F2F;
}

.record-count {
  font-size: 24rpx;
  color: #999999;
  text-align: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEEEEE;
}

.chart-card {
  padding: 24rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 24rpx;
}

.chart-container {
  padding: 0 20rpx;
}

.chart-row {
  display: flex;
  justify-content: space-around;
}

.chart-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 180rpx;
}

.bar-value-top {
  font-size: 22rpx;
  color: #333333;
  font-weight: 500;
}

.bar-value-bottom {
  font-size: 22rpx;
  color: #333333;
  font-weight: 500;
  margin-top: 8rpx;
}

.bar {
  width: 40rpx;
  border-radius: 4rpx 4rpx 0 0;
}

.bar.blue-out {
  background: linear-gradient(180deg, #1565C0 0%, #0D47A1 100%);
}

.bar.blue-in {
  background: linear-gradient(180deg, #42A5F5 0%, #1E88E5 100%);
}

.bar.red-out {
  background: linear-gradient(180deg, #C62828 0%, #B71C1C 100%);
}

.bar.red-in {
  background: linear-gradient(180deg, #EF5350 0%, #E53935 100%);
}

.bar-label {
  font-size: 24rpx;
  color: #666666;
  margin-top: 12rpx;
}

.chart-legend {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEEEEE;
  gap: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #666666;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  margin-right: 6rpx;
}

.legend-blue-out {
  background-color: #0D47A1;
}

.legend-blue-in {
  background-color: #42A5F5;
}

.legend-red-out {
  background-color: #B71C1C;
}

.legend-red-in {
  background-color: #EF5350;
}

.group-list-card {
  padding: 24rpx;
  margin-top: 20rpx;
}

.group-list-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #EEEEEE;
}

.group-item {
  background-color: #FAFAFA;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.group-header {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: #FFFFFF;
}

.group-info {
  flex: 1;
}

.group-route {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 4rpx;
}

.group-plate {
  font-size: 24rpx;
  color: #666666;
}

.group-summary {
  display: flex;
  gap: 16rpx;
  font-size: 26rpx;
  margin-right: 16rpx;
}

.group-arrow {
  font-size: 20rpx;
  color: #999999;
  transition: transform 0.3s;
}

.group-arrow.expanded {
  transform: rotate(180deg);
}

.group-detail {
  padding: 0 20rpx 20rpx;
  background-color: #FAFAFA;
}

.group-detail.hidden {
  display: none;
}

.group-row {
  display: flex;
  justify-content: space-between;
  background-color: #FFFFFF;
  border-radius: 8rpx;
  padding: 16rpx;
}

.group-cell {
  flex: 1;
  text-align: center;
}

.cell-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.cell-values {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  font-size: 24rpx;
}

.blue-text {
  color: #1976D2;
}

.red-text {
  color: #D32F2F;
}

.route-summary-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.route-summary-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 16rpx;
}

.route-summary-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.route-summary-item {
  background-color: #F8F9FA;
  border-radius: 12rpx;
  padding: 16rpx;
}

.route-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.route-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
}

.route-record-count {
  font-size: 22rpx;
  color: #999999;
}

.route-stats-row {
  display: flex;
  gap: 16rpx;
}

.route-stat {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666666;
}

.stat-values {
  display: flex;
  gap: 8rpx;
  font-size: 24rpx;
}

.blue-stat .stat-label {
  color: #1976D2;
}

.red-stat .stat-label {
  color: #D32F2F;
}

.stat-out {
  color: #333333;
}

.stat-in {
  color: #666666;
}

.input-card {
  padding: 24rpx;
}

.input-section {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background-color: #FAFAFA;
  border-radius: 12rpx;
}

.input-section-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.collapse-section {
  margin-bottom: 16rpx;
  background-color: #FAFAFA;
  border-radius: 12rpx;
  overflow: hidden;
}

.collapse-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
}

.collapse-title {
  font-size: 28rpx;
  font-weight: 600;
}

.collapse-arrow {
  font-size: 20rpx;
  color: #999999;
  transition: transform 0.3s;
}

.collapse-arrow.expanded {
  transform: rotate(180deg);
}

.collapse-content {
  display: none;
  padding: 0 24rpx 20rpx;
}

.collapse-content.expanded {
  display: block;
}

.blue-title {
  color: #1976D2;
}

.red-title {
  color: #D32F2F;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-row-2 {
  display: flex;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.flex-1 {
  flex: 1;
}

.input-group:last-child {
  margin-bottom: 0;
}

.input-label {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.blue-label {
  color: #1976D2;
}

.red-label {
  color: #D32F2F;
}

.input-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.input-item {
  flex: 1;
  padding: 12rpx 8rpx;
  background-color: #FFFFFF;
  border-radius: 8rpx;
}

.input-name {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 10rpx;
  text-align: center;
}

.stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  padding: 6rpx;
}

.stepper-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  background-color: #FFFFFF;
  border-radius: 8rpx;
}

.stepper-input {
  width: 60rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 0 4rpx;
  background-color: #FFFFFF;
  border-radius: 6rpx;
}

.btn-row {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
}

.btn-row .btn-secondary {
  flex: 1;
  margin-top: 0;
}

.text-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.picker-row {
  display: flex;
  gap: 12rpx;
}

.picker-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #999999;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.picker-btn.has-value {
  color: #333333;
}

.inline-input {
  width: 100rpx;
  height: 72rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
  background-color: #E3F2FD;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.delete-btn {
  width: 48rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 32rpx;
  color: #FFFFFF;
  background-color: #CCCCCC;
  border-radius: 8rpx;
  opacity: 0;
  pointer-events: none;
}

.delete-btn.show {
  background-color: #D32F2F;
  opacity: 1;
  pointer-events: auto;
}

.remark-input {
  width: 100%;
  min-height: 40rpx;
  padding: 12rpx;
  font-size: 28rpx;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.submit-btn {
  margin-top: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #1976D2 0%, #1565C0 100%);
  border-radius: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(25, 118, 210, 0.3);
}
