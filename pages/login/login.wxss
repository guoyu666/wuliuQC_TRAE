.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(135deg, #1E88E5 0%, #1565C0 50%, #0D47A1 100%);
  position: relative;
  overflow: hidden;
}

.bg-decoration {
  position: absolute;
  width: 100%;
  height: 100%;
  top: 0;
  left: 0;
  overflow: hidden;
  pointer-events: none;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
}

.bg-circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: -100rpx;
  right: -100rpx;
}

.bg-circle-2 {
  width: 300rpx;
  height: 300rpx;
  bottom: 80rpx;
  left: -80rpx;
}

.bg-circle-3 {
  width: 200rpx;
  height: 200rpx;
  top: 35%;
  right: -50rpx;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 100rpx 48rpx 40rpx;
  position: relative;
  z-index: 1;
}

.logo-section {
  text-align: center;
  margin-bottom: 48rpx;
}

.logo-wrapper {
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 32rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.logo {
  font-size: 64rpx;
}

.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
}

.login-card {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 28rpx;
  padding: 44rpx 36rpx;
  box-shadow: 0 20rpx 56rpx rgba(0, 0, 0, 0.2);
}

.welcome-text {
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.welcome-hint {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 36rpx;
}

.wechat-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  color: #FFFFFF;
  border-radius: 14rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 10rpx 20rpx rgba(7, 193, 96, 0.3);
  margin-bottom: 28rpx;
}

.wechat-login-btn:active {
  transform: scale(0.98);
}

.wechat-login-btn::after {
  border: none;
}

.wechat-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 12rpx;
}

.agreement {
  text-align: center;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 32rpx;
  line-height: 1.8;
  padding-bottom: 40rpx;
}

.link {
  color: #FFFFFF;
  font-weight: 500;
}
