.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666666;
  background-color: #FFFFFF;
}

.tab-item.active {
  background-color: #1976D2;
  color: #FFFFFF;
  font-weight: 500;
}

.date-selector {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.date-picker-wrap {
  flex: 1;
}

.date-display {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.date-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.date-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.date-arrow {
  font-size: 18rpx;
  color: #999999;
  margin-left: 8rpx;
}

.quick-btns {
  display: flex;
  gap: 8rpx;
  margin-left: 16rpx;
}

.quick-btn {
  padding: 16rpx 20rpx;
  font-size: 24rpx;
  color: #1976D2;
  background-color: #FFFFFF;
  border-radius: 8rpx;
  white-space: nowrap;
}

.summary-card {
  padding: 24rpx;
}

.summary-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  text-align: center;
  margin-bottom: 24rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.summary-item {
  text-align: center;
  padding: 16rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: bold;
}

.summary-value.blue {
  color: #1976D2;
}

.summary-value.red {
  color: #D32F2F;
}

.summary-total {
  text-align: center;
  font-size: 26rpx;
  color: #333333;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEEEEE;
}

.chart-card {
  padding: 24rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 24rpx;
}

.chart-container {
  padding: 20rpx 0;
}

.chart-bar-group {
  display: flex;
  justify-content: center;
  align-items: flex-end;
  height: 220rpx;
  gap: 80rpx;
}

.chart-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-group-vertical {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.bar {
  width: 50rpx;
  border-radius: 6rpx 6rpx 0 0;
}

.bar.blue-out {
  background: linear-gradient(180deg, #1565C0 0%, #0D47A1 100%);
}

.bar.blue-in {
  background: linear-gradient(180deg, #42A5F5 0%, #1E88E5 100%);
}

.bar.red-out {
  background: linear-gradient(180deg, #C62828 0%, #B71C1C 100%);
}

.bar.red-in {
  background: linear-gradient(180deg, #EF5350 0%, #E53935 100%);
}

.bar-label {
  font-size: 24rpx;
  color: #666666;
  margin-top: 12rpx;
}

.bar-value {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-top: 8rpx;
}

.trend-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.trend-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.trend-item:last-child {
  border-bottom: none;
}

.trend-date {
  font-size: 24rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.trend-content {
  display: flex;
  gap: 24rpx;
}

.trend-group {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.trend-bar {
  height: 24rpx;
  border-radius: 4rpx;
  min-width: 4rpx;
}

.trend-bar.blue-out {
  background-color: #1976D2 !important;
}

.trend-bar.blue-in {
  background-color: #42A5F5 !important;
}

.trend-bar.red-out {
  background-color: #D32F2F !important;
}

.trend-bar.red-in {
  background-color: #EF5350 !important;
}

.trend-num {
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
}

.trend-num.blue {
  color: #1976D2;
}

.trend-num.red {
  color: #D32F2F;
}

.trend-legend {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.trend-legend .legend-item {
  display: flex;
  align-items: center;
  font-size: 20rpx;
  color: #666666;
}

.trend-legend .legend-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 3rpx;
  margin-right: 4rpx;
}

.trend-legend .legend-blue-out {
  background-color: #1976D2;
}

.trend-legend .legend-blue-in {
  background-color: #42A5F5;
}

.legend-red-out {
  background-color: #D32F2F;
}

.legend-red-in {
  background-color: #EF5350;
}

.trend-legend .legend-red-out {
  background-color: #D32F2F;
}

.trend-legend .legend-red-in {
  background-color: #EF5350;
}

.empty-tip {
  text-align: center;
  color: #999999;
  font-size: 28rpx;
  padding: 60rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-tip::before {
  content: '📊';
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.chart-legend {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEEEEE;
  gap: 24rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #666666;
}

.legend-color {
  width: 20rpx;
  height: 20rpx;
  border-radius: 4rpx;
  margin-right: 6rpx;
}

.legend-blue-out {
  background-color: #1565C0;
}

.legend-blue-in {
  background-color: #42A5F5;
}
