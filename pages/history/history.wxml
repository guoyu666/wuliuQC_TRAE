<view class="container">
  <view class="search-bar">
    <view class="search-input-wrap">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索线路/车牌/备注" value="{{searchKeyword}}" bindinput="onSearchInput" bindconfirm="doSearch" confirm-type="search" />
      <view class="clear-btn {{searchKeyword ? 'show' : ''}}" bindtap="clearSearch">×</view>
    </view>
    <view class="filter-btn" bindtap="toggleFilter">{{showFilter ? '收起' : '筛选'}}</view>
  </view>

  <view class="filter-panel {{showFilter ? 'show' : ''}}">
    <view class="filter-row">
      <picker mode="date" value="{{filterStartDate}}" start="2020-01-01" end="2099-12-31" bindchange="onFilterStartDateChange">
        <view class="filter-item">
          <view class="filter-label">开始日期</view>
          <view class="filter-value {{filterStartDate ? 'has-value' : ''}}">{{filterStartDate || '不限'}}</view>
        </view>
      </picker>
      <view class="filter-gap">至</view>
      <picker mode="date" value="{{filterEndDate}}" start="2020-01-01" end="2099-12-31" bindchange="onFilterEndDateChange">
        <view class="filter-item">
          <view class="filter-label">结束日期</view>
          <view class="filter-value {{filterEndDate ? 'has-value' : ''}}">{{filterEndDate || '不限'}}</view>
        </view>
      </picker>
    </view>
    <view class="filter-actions">
      <view class="filter-reset" bindtap="resetFilter">重置</view>
      <view class="filter-apply" bindtap="applyFilter">应用</view>
    </view>
  </view>

  <view class="search-result-tip" wx:if="{{isSearching}}">
    找到 {{filteredRecordCount}} 条记录
  </view>

  <view class="export-bar">
    <view class="export-btn {{isSearching ? 'highlight' : ''}}" bindtap="showExportModal">
      <text class="export-icon">📤</text>
      <text>{{isSearching ? '导出筛选结果' : '导出记录'}}</text>
    </view>
    <view class="backup-btn" bindtap="showBackupModal">
      <text class="backup-icon">💾</text>
      <text>备份</text>
    </view>
  </view>

  <view class="empty-state" wx:if="{{displayGroupedRecords.length === 0}}">
    <view class="empty-icon">📋</view>
    <view class="empty-text">暂无记录</view>
    <view class="empty-hint">请在首页添加收发记录</view>
  </view>

  <view class="record-group" wx:for="{{displayGroupedRecords}}" wx:key="date">
    <view class="date-header">
      <view class="date-line"></view>
      <view class="date-badge">{{item.date}}</view>
      <view class="date-line"></view>
    </view>
    <view class="summary-card card">
      <view class="summary-row">
        <view class="summary-item blue">
          <view class="summary-label">蓝出</view>
          <view class="summary-value">{{item.blueOut}}</view>
        </view>
        <view class="summary-item blue">
          <view class="summary-label">蓝入</view>
          <view class="summary-value">{{item.blueIn}}</view>
        </view>
        <view class="summary-item red">
          <view class="summary-label">红出</view>
          <view class="summary-value">{{item.redOut}}</view>
        </view>
        <view class="summary-item red">
          <view class="summary-label">红入</view>
          <view class="summary-value">{{item.redIn}}</view>
        </view>
      </view>
    </view>
    <view class="record-items">
      <view class="record-item" wx:for="{{item.records}}" wx:for-item="record" wx:key="id">
        <view class="record-content">
          <view class="record-header">
            <view class="record-route">{{record.routeName}}</view>
            <view class="record-plate">{{record.plateNumber}}</view>
          </view>
          <view class="record-time">{{record.createTime}}</view>
          <view class="record-detail">
            <text wx:if="{{record.sendBlueOut > 0}}" class="blue-text">发蓝:{{record.sendBlueOut}} </text>
            <text wx:if="{{record.sendRedOut > 0}}" class="red-text">发红:{{record.sendRedOut}} </text>
            <text wx:if="{{record.blueOut > 0}}" class="blue-text">蓝出:{{record.blueOut}} </text>
            <text wx:if="{{record.blueIn > 0}}" class="blue-text">蓝入:{{record.blueIn}} </text>
            <text wx:if="{{record.redOut > 0}}" class="red-text">红出:{{record.redOut}} </text>
            <text wx:if="{{record.redIn > 0}}" class="red-text">红入:{{record.redIn}}</text>
          </view>
          <view class="record-remark" wx:if="{{record.remark}}">备注: {{record.remark}}</view>
        </view>
        <view class="record-actions">
          <view class="edit-btn" bindtap="editData" data-id="{{record.id}}">编辑</view>
          <view class="remark-btn" bindtap="editRemark" data-id="{{record.id}}" data-remark="{{record.remark}}">备注</view>
          <view class="delete-btn" bindtap="deleteRecord" data-id="{{record.id}}">删除</view>
        </view>
      </view>
    </view>
  </view>

  <view class="loading-more" wx:if="{{hasMore}}">
    <view class="loading-text">加载中...</view>
  </view>

  <view class="no-more" wx:if="{{!hasMore && displayGroupedRecords.length > 0}}">
    <view class="no-more-text">没有更多了</view>
  </view>

  <view class="modal-mask" wx:if="{{showExportModal}}" bindtap="hideExportModal"></view>
  <view class="modal-content" wx:if="{{showExportModal}}">
    <view class="modal-header">导出历史记录</view>
    <view class="modal-body">
      <view class="date-range">
        <view class="date-item">
          <view class="date-label">开始日期</view>
          <picker mode="date" value="{{startDate}}" start="2020-01-01" end="2099-12-31" bindchange="onStartDateChange">
            <view class="date-picker">{{startDate || '请选择'}}</view>
          </picker>
        </view>
        <view class="date-item">
          <view class="date-label">结束日期</view>
          <picker mode="date" value="{{endDate}}" start="2020-01-01" end="2099-12-31" bindchange="onEndDateChange">
            <view class="date-picker">{{endDate || '请选择'}}</view>
          </picker>
        </view>
      </view>
      <view class="export-preview" wx:if="{{exportRecords.length > 0}}">
        <view class="preview-title">将导出 {{exportRecords.length}} 条记录为 Excel 格式</view>
        <view class="preview-stats">
          <view class="stat-item blue">蓝出: {{exportStats.blueOut}}</view>
          <view class="stat-item blue">蓝入: {{exportStats.blueIn}}</view>
          <view class="stat-item red">红出: {{exportStats.redOut}}</view>
          <view class="stat-item red">红入: {{exportStats.redIn}}</view>
        </view>
      </view>
      <view class="export-preview" wx:else>
        <view class="preview-title">请选择日期范围</view>
      </view>
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="hideExportModal">取消</view>
      <view class="modal-btn confirm excel-btn" bindtap="exportRecords">导出 Excel</view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showDataModal}}" bindtap="hideDataModal"></view>
  <view class="modal-content" wx:if="{{showDataModal}}">
    <view class="modal-header">编辑数据</view>
    <view class="modal-body">
      <view class="edit-group">
        <view class="edit-label">线路名称</view>
        <view class="edit-picker-row">
          <picker mode="selector" range="{{routeList}}" value="{{editRouteIndex}}" bindchange="onEditRouteChange">
            <view class="edit-picker-btn {{editRouteIndex >= 0 ? 'has-value' : ''}}">
              {{editRouteIndex >= 0 ? routeList[editRouteIndex] : '选择线路'}}
            </view>
          </picker>
          <input class="edit-inline-input" placeholder="+新增" value="{{newEditRouteName}}" bindinput="onNewEditRouteNameInput" bindconfirm="addNewEditRoute" confirm-type="done" />
        </view>
      </view>
      <view class="edit-group">
        <view class="edit-label">车牌号</view>
        <view class="edit-picker-row">
          <picker mode="selector" range="{{plateList}}" value="{{editPlateIndex}}" bindchange="onEditPlateChange">
            <view class="edit-picker-btn {{editPlateIndex >= 0 ? 'has-value' : ''}}">
              {{editPlateIndex >= 0 ? plateList[editPlateIndex] : '选择车牌'}}
            </view>
          </picker>
          <input class="edit-inline-input" placeholder="+新增" value="{{newEditPlateNumber}}" bindinput="onNewEditPlateNumberInput" bindconfirm="addNewEditPlate" confirm-type="done" />
        </view>
      </view>
      <view class="edit-group">
        <view class="edit-label blue">物流发出</view>
        <view class="edit-row">
          <view class="edit-item">
            <view class="edit-name">蓝框</view>
            <view class="edit-stepper">
              <view class="stepper-btn" bindtap="adjustEditValue" data-field="editSendBlueOut" data-delta="-1">-</view>
              <input class="stepper-input" type="number" value="{{editSendBlueOut}}" bindinput="onEditSendBlueOutChange" />
              <view class="stepper-btn" bindtap="adjustEditValue" data-field="editSendBlueOut" data-delta="1">+</view>
            </view>
          </view>
          <view class="edit-item">
            <view class="edit-name">红框</view>
            <view class="edit-stepper">
              <view class="stepper-btn" bindtap="adjustEditValue" data-field="editSendRedOut" data-delta="-1">-</view>
              <input class="stepper-input" type="number" value="{{editSendRedOut}}" bindinput="onEditSendRedOutChange" />
              <view class="stepper-btn" bindtap="adjustEditValue" data-field="editSendRedOut" data-delta="1">+</view>
            </view>
          </view>
        </view>
      </view>
      <view class="edit-group">
        <view class="edit-label blue">蓝色框子</view>
        <view class="edit-row">
          <view class="edit-item">
            <view class="edit-name">发出</view>
            <view class="edit-stepper">
              <view class="stepper-btn" bindtap="adjustEditValue" data-field="editBlueOut" data-delta="-1">-</view>
              <input class="stepper-input" type="number" value="{{editBlueOut}}" bindinput="onEditBlueOutChange" />
              <view class="stepper-btn" bindtap="adjustEditValue" data-field="editBlueOut" data-delta="1">+</view>
            </view>
          </view>
          <view class="edit-item">
            <view class="edit-name">收回</view>
            <view class="edit-stepper">
              <view class="stepper-btn" bindtap="adjustEditValue" data-field="editBlueIn" data-delta="-1">-</view>
              <input class="stepper-input" type="number" value="{{editBlueIn}}" bindinput="onEditBlueInChange" />
              <view class="stepper-btn" bindtap="adjustEditValue" data-field="editBlueIn" data-delta="1">+</view>
            </view>
          </view>
        </view>
      </view>
      <view class="edit-group">
        <view class="edit-label red">红色框子</view>
        <view class="edit-row">
          <view class="edit-item">
            <view class="edit-name">发出</view>
            <view class="edit-stepper">
              <view class="stepper-btn" bindtap="adjustEditValue" data-field="editRedOut" data-delta="-1">-</view>
              <input class="stepper-input" type="number" value="{{editRedOut}}" bindinput="onEditRedOutChange" />
              <view class="stepper-btn" bindtap="adjustEditValue" data-field="editRedOut" data-delta="1">+</view>
            </view>
          </view>
          <view class="edit-item">
            <view class="edit-name">收回</view>
            <view class="edit-stepper">
              <view class="stepper-btn" bindtap="adjustEditValue" data-field="editRedIn" data-delta="-1">-</view>
              <input class="stepper-input" type="number" value="{{editRedIn}}" bindinput="onEditRedInChange" />
              <view class="stepper-btn" bindtap="adjustEditValue" data-field="editRedIn" data-delta="1">+</view>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="hideDataModal">取消</view>
      <view class="modal-btn confirm" bindtap="saveData">保存</view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showRemarkModal}}" bindtap="hideRemarkModal"></view>
  <view class="modal-content" wx:if="{{showRemarkModal}}">
    <view class="modal-header">编辑备注</view>
    <view class="modal-body">
      <textarea class="remark-edit-input" placeholder="请输入备注..." value="{{editRemark}}" bindinput="onEditRemarkChange" maxlength="200"></textarea>
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="hideRemarkModal">取消</view>
      <view class="modal-btn confirm" bindtap="saveRemark">保存</view>
    </view>
  </view>

  <view class="modal-mask" wx:if="{{showBackupModal}}" bindtap="hideBackupModal"></view>
  <view class="modal-content" wx:if="{{showBackupModal}}">
    <view class="modal-header">数据备份与恢复</view>
    <view class="modal-body">
      <view class="backup-section">
        <view class="backup-title">导出备份</view>
        <view class="backup-desc">将所有记录导出为 JSON 文件保存</view>
        <view class="backup-btn-main" bindtap="exportBackup">导出备份文件</view>
      </view>
      <view class="backup-divider"></view>
      <view class="backup-section">
        <view class="backup-title">导入恢复</view>
        <view class="backup-desc">从备份文件恢复数据（会覆盖现有数据）</view>
        <view class="restore-btn-main" bindtap="importBackup">选择备份文件</view>
      </view>
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="hideBackupModal">关闭</view>
    </view>
  </view>
</view>