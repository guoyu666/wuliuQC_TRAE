.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-muted);
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 0;
  margin-bottom: 16rpx;
}

.search-input-wrap {
  min-height: 76rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  font-weight: 500;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 32rpx;
  color: var(--text-muted);
  opacity: 0;
  pointer-events: none;
}

.clear-btn.show {
  opacity: 1;
  pointer-events: auto;
}

.filter-btn {
  padding: 16rpx 26rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.filter-panel {
  display: none;
  background-color: var(--bg-muted);
  border-radius: 20rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid var(--border-color);
}

.filter-panel.show {
  display: block;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
}

.filter-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.filter-value {
  font-size: 26rpx;
  padding: 16rpx 12rpx;
  font-weight: 500;
}

.filter-value.has-value {
  color: var(--blue-color);
}

.filter-gap {
  padding: 0 16rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.filter-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.filter-reset {
  padding: 14rpx 34rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.filter-apply {
  padding: 14rpx 34rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.search-result-tip {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 8rpx 0;
  margin-bottom: 8rpx;
}

.export-bar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.export-btn {
  display: flex;
  align-items: center;
  padding: 14rpx 24rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.export-btn.highlight {
  color: var(--text-on-primary);
}

.export-icon {
  margin-right: 8rpx;
}

.sync-card {
  background-color: var(--bg-card);
  border: 1rpx solid var(--border-color);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-control);
}

.sync-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.sync-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.sync-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.sync-action {
  flex-shrink: 0;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-on-primary);
  background: linear-gradient(135deg, var(--blue-color) 0%, var(--blue-color-strong) 100%);
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
}

.sync-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.sync-chip {
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.sync-chip.synced {
  color: var(--green-color);
  background-color: var(--success-bg);
}

.sync-chip.pending {
  color: var(--blue-color);
  background-color: var(--blue-bg);
}

.sync-chip.delete {
  color: var(--red-color);
  background-color: var(--red-bg);
}

.sync-chip.restore {
  color: var(--warning-color);
  background-color: var(--warning-bg);
}

.sync-error {
  margin-top: 14rpx;
  font-size: 22rpx;
  color: var(--red-color);
  line-height: 1.45;
}

.sync-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 14rpx;
}

.sync-cancel {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 10rpx 0;
}

.record-group {
  margin-bottom: 32rpx;
}

.date-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  padding: 0 20rpx;
}

.date-line {
  flex: 1;
  height: 1rpx;
  background-color: var(--border-color);
}

.date-badge {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: var(--text-on-primary);
  background-color: var(--blue-color);
  border-radius: 24rpx;
  margin: 0 20rpx;
}

.summary-card {
  padding: 16rpx 24rpx;
}

.summary-row {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
  padding: 8rpx 0;
}

.summary-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.summary-value {
  font-size: 32rpx;
  font-weight: bold;
}

.summary-item.blue .summary-value {
  color: var(--blue-color);
}

.summary-item.red .summary-value {
  color: var(--red-color);
}

.record-items {
  margin-top: 12rpx;
}

.record-swipe {
  position: relative;
  overflow: hidden;
  border-radius: 20rpx;
  margin-bottom: 10rpx;
}

.record-delete-action {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 168rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-on-primary);
  background: linear-gradient(135deg, var(--red-color) 0%, var(--red-color-strong) 100%);
}

.delete-icon {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.record-item {
  position: relative;
  z-index: 1;
  background-color: var(--bg-card);
  border-radius: 20rpx;
  padding: 18rpx;
  box-shadow: var(--shadow-control);
  border: 1rpx solid var(--card-border-soft);
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
}

.record-swipe.is-open .record-item {
  transform: translateX(-168rpx);
  border-color: var(--red-color);
  box-shadow: 0 10rpx 22rpx var(--danger-shadow);
}

.record-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.record-route {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
}

.record-edit-tag {
  flex-shrink: 0;
  font-size: 20rpx;
  color: var(--blue-color);
  background-color: var(--blue-bg);
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.record-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.record-plate {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.record-time {
  font-size: 20rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.record-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.stat-chip {
  font-size: 20rpx;
  line-height: 1;
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  font-weight: 600;
}

.blue-chip {
  color: var(--blue-color);
  background-color: var(--blue-bg);
}

.red-chip {
  color: var(--red-color);
  background-color: var(--red-bg);
}

.neutral-chip {
  color: var(--text-secondary);
  background-color: var(--bg-muted);
}

.record-remark {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
  padding: 10rpx 12rpx;
  background-color: var(--bg-muted);
  border-radius: 10rpx;
  line-height: 1.5;
}

.record-hint {
  margin-top: 10rpx;
  font-size: 18rpx;
  color: var(--text-muted);
}

.record-swipe.is-open .record-hint {
  color: var(--red-color-strong);
  font-weight: 600;
}

.loading-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-muted);
}

.no-more-text {
  font-size: 26rpx;
  color: var(--text-muted);
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--overlay-scrim);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  background-color: var(--bg-card);
  border-radius: 16rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-header {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid var(--border-color);
}

.modal-body {
  padding: 32rpx;
}

.date-range {
  display: flex;
  justify-content: space-between;
}

.date-item {
  flex: 1;
  margin: 0 10rpx;
}

.date-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
  text-align: center;
}

.date-picker {
  background-color: var(--bg-muted);
  border-radius: 8rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-primary);
}

.export-preview {
  margin-top: 32rpx;
  padding: 24rpx;
  background-color: var(--bg-muted);
  border-radius: 8rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 16rpx;
}

.preview-stats {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
}

.stat-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 8rpx 16rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid var(--border-color);
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
}

.modal-btn.cancel {
  color: var(--text-muted);
  border-right: 1rpx solid var(--border-color);
}

.modal-btn.confirm {
  color: var(--blue-color);
  font-weight: 500;
}

.backup-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 20rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.backup-icon {
  font-size: 28rpx;
}

.backup-section {
  padding: 16rpx 0;
}

.backup-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.backup-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.backup-divider {
  height: 1rpx;
  background-color: var(--border-color);
  margin: 16rpx 0;
}

.backup-btn-main {
  background-color: var(--blue-color);
  color: var(--text-on-primary);
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
}

.restore-btn-main {
  background-color: var(--warning-color-strong);
  color: var(--text-on-primary);
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
}

.excel-btn {
  background: linear-gradient(135deg, var(--blue-color) 0%, var(--blue-color-strong) 100%);
}

.modal-btn.confirm.excel-btn {
  color: var(--text-on-primary);
  font-weight: 700;
  letter-spacing: 1rpx;
}

.edit-group {
  margin-bottom: 32rpx;
}

.edit-group:last-child {
  margin-bottom: 0;
}

.edit-label {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.edit-label.blue {
  color: var(--blue-color);
}

.edit-label.red {
  color: var(--red-color);
}

.edit-picker-row {
  display: flex;
  gap: 12rpx;
}

.edit-picker-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: var(--text-muted);
  background-color: var(--bg-muted);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.edit-picker-btn.has-value {
  color: var(--text-primary);
}

.edit-inline-input {
  width: 100rpx;
  height: 72rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
  background-color: var(--blue-bg);
  border-radius: 8rpx;
  box-sizing: border-box;
}

.edit-row {
  display: flex;
  justify-content: space-between;
}

.edit-item {
  flex: 1;
  padding: 0 8rpx;
}

.edit-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-bottom: 12rpx;
}

.edit-stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-muted);
  border-radius: 8rpx;
  padding: 8rpx;
}

.edit-stepper .stepper-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  background-color: var(--bg-card);
  border-radius: 6rpx;
}

.edit-stepper .stepper-input {
  width: 70rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 0 6rpx;
  background-color: var(--bg-card);
  border-radius: 6rpx;
}

.remark-edit-input {
  width: 100%;
  min-height: 200rpx;
  padding: 16rpx;
  font-size: 28rpx;
  background-color: var(--bg-muted);
  border-radius: 8rpx;
  box-sizing: border-box;
}
