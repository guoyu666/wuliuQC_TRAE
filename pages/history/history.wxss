.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #F5F5F5;
  border-radius: 36rpx;
  padding: 0 20rpx;
  height: 72rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
}

.clear-btn {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 32rpx;
  color: #999999;
  opacity: 0;
  pointer-events: none;
}

.clear-btn.show {
  opacity: 1;
  pointer-events: auto;
}

.filter-btn {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  color: #1976D2;
  background-color: #E3F2FD;
  border-radius: 8rpx;
}

.filter-panel {
  display: none;
  background-color: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.filter-panel.show {
  display: block;
}

.filter-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
}

.filter-label {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.filter-value {
  font-size: 26rpx;
  color: #333333;
  padding: 12rpx;
  background-color: #FFFFFF;
  border-radius: 8rpx;
}

.filter-value.has-value {
  color: #1976D2;
}

.filter-gap {
  padding: 0 16rpx;
  color: #999999;
  font-size: 26rpx;
}

.filter-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #E0E0E0;
}

.filter-reset {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  color: #666666;
  background-color: #FFFFFF;
  border-radius: 8rpx;
}

.filter-apply {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  color: #FFFFFF;
  background-color: #1976D2;
  border-radius: 8rpx;
}

.search-result-tip {
  font-size: 24rpx;
  color: #666666;
  padding: 8rpx 0;
  margin-bottom: 8rpx;
}

.export-bar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.export-btn {
  display: flex;
  align-items: center;
  background-color: #1976D2;
  color: #FFFFFF;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.export-btn.highlight {
  background-color: #4CAF50;
}

.export-icon {
  margin-right: 8rpx;
}

.record-group {
  margin-bottom: 32rpx;
}

.date-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  padding: 0 20rpx;
}

.date-line {
  flex: 1;
  height: 1rpx;
  background-color: #E0E0E0;
}

.date-badge {
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #FFFFFF;
  background-color: #1976D2;
  border-radius: 24rpx;
  margin: 0 20rpx;
}

.summary-card {
  padding: 16rpx 24rpx;
}

.summary-row {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
  padding: 8rpx 0;
}

.summary-label {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.summary-value {
  font-size: 32rpx;
  font-weight: bold;
}

.summary-item.blue .summary-value {
  color: #1976D2;
}

.summary-item.red .summary-value {
  color: #D32F2F;
}

.record-items {
  margin-top: 12rpx;
}

.record-item {
  display: flex;
  align-items: flex-start;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.record-time {
  font-size: 20rpx;
  color: #999999;
  width: 140rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.record-detail {
  flex: 1;
  font-size: 24rpx;
  color: #333333;
  line-height: 1.6;
}

.record-remark {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
  padding: 6rpx 12rpx;
  background-color: #F5F5F5;
  border-radius: 4rpx;
}

.record-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.edit-btn {
  font-size: 22rpx;
  color: #1976D2;
  padding: 10rpx 16rpx;
  background-color: #E3F2FD;
  border-radius: 6rpx;
}

.remark-btn {
  font-size: 22rpx;
  color: #FF9800;
  padding: 10rpx 16rpx;
  background-color: #FFF3E0;
  border-radius: 6rpx;
}

.delete-btn {
  font-size: 22rpx;
  color: #D32F2F;
  padding: 10rpx 16rpx;
  background-color: #FFEBEE;
  border-radius: 6rpx;
}

.record-content {
  flex: 1;
}

.loading-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #999999;
}

.no-more-text {
  font-size: 26rpx;
  color: #BBBBBB;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-header {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.modal-body {
  padding: 32rpx;
}

.date-range {
  display: flex;
  justify-content: space-between;
}

.date-item {
  flex: 1;
  margin: 0 10rpx;
}

.date-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
  text-align: center;
}

.date-picker {
  background-color: #F5F5F5;
  border-radius: 8rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333333;
}

.export-preview {
  margin-top: 32rpx;
  padding: 24rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 16rpx;
}

.preview-stats {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
}

.stat-item {
  font-size: 24rpx;
  color: #666666;
  padding: 8rpx 16rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #EEEEEE;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
}

.modal-btn.cancel {
  color: #999999;
  border-right: 1rpx solid #EEEEEE;
}

.modal-btn.confirm {
  color: #1976D2;
  font-weight: 500;
}

.backup-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background-color: #4CAF50;
  color: #FFFFFF;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.backup-icon {
  font-size: 28rpx;
}

.backup-section {
  padding: 16rpx 0;
}

.backup-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 8rpx;
}

.backup-desc {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.backup-divider {
  height: 1rpx;
  background-color: #EEEEEE;
  margin: 16rpx 0;
}

.backup-btn-main {
  background-color: #1976D2;
  color: #FFFFFF;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
}

.restore-btn-main {
  background-color: #FF9800;
  color: #FFFFFF;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28rpx;
}

.edit-group {
  margin-bottom: 32rpx;
}

.edit-group:last-child {
  margin-bottom: 0;
}

.edit-label {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.edit-label.blue {
  color: #1976D2;
}

.edit-label.red {
  color: #D32F2F;
}

.edit-picker-row {
  display: flex;
  gap: 12rpx;
}

.edit-picker-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #999999;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.edit-picker-btn.has-value {
  color: #333333;
}

.edit-inline-input {
  width: 100rpx;
  height: 72rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
  background-color: #E3F2FD;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.edit-row {
  display: flex;
  justify-content: space-between;
}

.edit-item {
  flex: 1;
  padding: 0 8rpx;
}

.edit-name {
  font-size: 24rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 12rpx;
}

.edit-stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  padding: 8rpx;
}

.edit-stepper .stepper-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  background-color: #FFFFFF;
  border-radius: 6rpx;
}

.edit-stepper .stepper-input {
  width: 70rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 0 6rpx;
  background-color: #FFFFFF;
  border-radius: 6rpx;
}

.remark-edit-input {
  width: 100%;
  min-height: 200rpx;
  padding: 16rpx;
  font-size: 28rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  box-sizing: border-box;
}
