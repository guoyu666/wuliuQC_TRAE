.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #333333;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999999;
}

.export-bar {
  display: flex;
  justify-content: flex-end;
  margin-bottom: 20rpx;
}

.export-btn {
  display: flex;
  align-items: center;
  background-color: #1976D2;
  color: #FFFFFF;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.export-icon {
  margin-right: 8rpx;
}

.record-group {
  margin-bottom: 24rpx;
}

.date-header {
  padding: 12rpx 0;
}

.date-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
}

.summary-card {
  padding: 16rpx 24rpx;
}

.summary-row {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
  padding: 8rpx 0;
}

.summary-label {
  font-size: 22rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.summary-value {
  font-size: 32rpx;
  font-weight: bold;
}

.summary-item.blue .summary-value {
  color: #1976D2;
}

.summary-item.red .summary-value {
  color: #D32F2F;
}

.record-items {
  margin-top: 12rpx;
}

.record-item {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 22rpx;
  color: #999999;
  width: 180rpx;
  flex-shrink: 0;
}

.record-detail {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
}

.record-remark {
  font-size: 22rpx;
  color: #999999;
  margin-top: 6rpx;
  padding: 6rpx 12rpx;
  background-color: #F5F5F5;
  border-radius: 4rpx;
}

.record-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}

.edit-btn {
  font-size: 24rpx;
  color: #1976D2;
  padding: 8rpx 16rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #D32F2F;
  padding: 8rpx 16rpx;
}

.record-content {
  flex: 1;
}

.loading-more,
.no-more {
  text-align: center;
  padding: 32rpx 0;
}

.loading-text {
  font-size: 26rpx;
  color: #999999;
}

.no-more-text {
  font-size: 26rpx;
  color: #BBBBBB;
}

.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  z-index: 101;
  overflow: hidden;
}

.modal-header {
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.modal-body {
  padding: 32rpx;
}

.date-range {
  display: flex;
  justify-content: space-between;
}

.date-item {
  flex: 1;
  margin: 0 10rpx;
}

.date-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
  text-align: center;
}

.date-picker {
  background-color: #F5F5F5;
  border-radius: 8rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333333;
}

.export-preview {
  margin-top: 32rpx;
  padding: 24rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 16rpx;
}

.preview-stats {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
}

.stat-item {
  font-size: 24rpx;
  color: #666666;
  padding: 8rpx 16rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #EEEEEE;
}

.modal-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
}

.modal-btn.cancel {
  color: #999999;
  border-right: 1rpx solid #EEEEEE;
}

.modal-btn.confirm {
  color: #1976D2;
  font-weight: 500;
}

.edit-group {
  margin-bottom: 32rpx;
}

.edit-group:last-child {
  margin-bottom: 0;
}

.edit-label {
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.edit-label.blue {
  color: #1976D2;
}

.edit-label.red {
  color: #D32F2F;
}

.edit-row {
  display: flex;
  justify-content: space-between;
}

.edit-item {
  flex: 1;
  padding: 0 8rpx;
}

.edit-name {
  font-size: 24rpx;
  color: #666666;
  text-align: center;
  margin-bottom: 12rpx;
}

.edit-stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  padding: 8rpx;
}

.edit-stepper .stepper-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  background-color: #FFFFFF;
  border-radius: 6rpx;
}

.edit-stepper .stepper-input {
  width: 70rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  margin: 0 6rpx;
  background-color: #FFFFFF;
  border-radius: 6rpx;
}

.remark-btn {
  font-size: 24rpx;
  color: #FF9800;
  padding: 8rpx 16rpx;
}

.remark-edit-input {
  width: 100%;
  min-height: 200rpx;
  padding: 16rpx;
  font-size: 28rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  box-sizing: border-box;
}
